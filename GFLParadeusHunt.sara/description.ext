// ========================================================================
// KONTRAK MISI – UI DIALOG
// ========================================================================
class MERC_ContractBoard_Dialog {
    idd = 47400;                          // ID dialog unik
    movingEnable = 1;
    enableSimulation = 1;

    class controlsBackground {
        // Latar belakang semi‑transparan
        class Background : RscText {
            idc = 47401;
            x = 0.25 * safezoneW + safezoneX;
            y = 0.2 * safezoneH + safezoneY;
            w = 0.5 * safezoneW;
            h = 0.6 * safezoneH;
            colorBackground[] = {0,0,0,0.85};
        };
        // Bingkai judul
        class TitleBar : RscText {
            idc = 47402;
            x = 0.25 * safezoneW + safezoneX;
            y = 0.18 * safezoneH + safezoneY;
            w = 0.5 * safezoneW;
            h = 0.025 * safezoneH;
            colorBackground[] = {0.8,0.3,0,1};   // Merah‑jingga
            text = "  CONTRACT BOARD";
        };
    };

    class controls {
        // Listbox daftar misi
        class MissionList : RscListBox {
            idc = 47410;
            x = 0.27 * safezoneW + safezoneX;
            y = 0.25 * safezoneH + safezoneY;
            w = 0.46 * safezoneW;
            h = 0.25 * safezoneH;
            rowHeight = 0.05 * safezoneH;
            sizeEx = 0.035 * safezoneH;
        };

        // Informasi detail misi yang dipilih
        class MissionInfo : RscStructuredText {
            idc = 47411;
            x = 0.27 * safezoneW + safezoneX;
            y = 0.51 * safezoneH + safezoneY;
            w = 0.46 * safezoneW;
            h = 0.18 * safezoneH;
            sizeEx = 0.035 * safezoneH;
        };

        // Tombol terima misi
        class AcceptButton : RscButton {
