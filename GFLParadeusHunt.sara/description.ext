// --- Notifikasi Visual ---
class CfgNotifications {
    class Default {
        title = ""; iconPicture = ""; description = "";
        color[] = {1,1,1,1}; duration = 5;
    };
    class AutoSaveNotification {
        title = "GFL DATA SAVED";
        description = "%1";
        iconPicture = "ATTENTION";
        color[] = {0.2, 1, 0.2, 1};
    };
    class HQDestroyed {
        title = "GFL HQ LOST";
        description = "%1";
        iconPicture = "KIA";
        color[] = {1, 0, 0, 1};
    };
};

