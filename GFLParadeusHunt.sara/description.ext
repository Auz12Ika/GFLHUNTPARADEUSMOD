// --- Info Dasar ---
author = "";
onLoadName = "GFL Insurgency";
onLoadMission = "Mercenary Operations vs Cult. PVE/PVP Sandbox. 7 HQ to destroy.";
loadScreen = "";

// --- Konfigurasi Slotting & Server ---
class Header {
    gameType = "Sandbox";
    minPlayers = 1;
    maxPlayers = 20;
};

// --- Multiplayer & Flow Control ---
disabledAI = 1;
joinUnassigned = 1;
skipLobby = 0;
forceRotorLibSimulation = 0;
enableDebugConsole = 1;

// --- Aturan Respawn ---
respawn = 3;
respawnDelay = 15;
respawnDialog = 0;
respawnTemplates[] = {"MenuPosition"};
respawnOnStart = 0;

// --- Garbage Collector ---
corpseManagerMode = 1;
corpseLimit = 30;
corpseRemovalMinTime = 60;
corpseRemovalMaxTime = 300;

wreckManagerMode = 1;
wreckLimit = 10;
wreckRemovalMinTime = 120;
wreckRemovalMaxTime = 600;

onPlayerConnected = "";
onPlayerDisconnected = "";

